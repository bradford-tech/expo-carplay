+#pragma mark - Navigation Cursor Snapping
+
+static const CLLocationDistance kSnapOffThreshold = 15.0;
+static const CLLocationDistance kSnapOnThreshold  =  8.0;
+static const CLLocationDistance kFullScanMovementThreshold = 50.0;
+static const NSInteger kWindowRadius = 10;
+
+static MKMapPoint projectPointOntoSegment(MKMapPoint point, MKMapPoint segStart, MKMapPoint segEnd) {
+    double dx = segEnd.x - segStart.x;
+    double dy = segEnd.y - segStart.y;
+    double lengthSq = dx * dx + dy * dy;
+    if (lengthSq == 0) return segStart;
+    double t = fmax(0, fmin(1,
+        ((point.x - segStart.x) * dx + (point.y - segStart.y) * dy) / lengthSq
+    ));
+    return MKMapPointMake(segStart.x + t * dx, segStart.y + t * dy);
+}
+
+typedef struct {
+    MKMapPoint projectedPoint;
+    double perpDistance;
+    NSInteger segmentIndex;
+} SnapResult;
+
+// bearingBetweenCoordinates consolidated into AIRMapBearing() in AIRMap.h
+
+static SnapResult findClosestSegment(MKMapPoint userPoint, MKMapPoint *polyline, NSInteger pointCount, NSInteger fromIndex, NSInteger toIndex) {
+    SnapResult best = { .projectedPoint = userPoint, .perpDistance = DBL_MAX, .segmentIndex = -1 };
+    if (fromIndex < 0) fromIndex = 0;
+    if (toIndex >= pointCount - 1) toIndex = pointCount - 2;
+
+    for (NSInteger i = fromIndex; i <= toIndex; i++) {
+        MKMapPoint projected = projectPointOntoSegment(userPoint, polyline[i], polyline[i + 1]);
+        double dist = MKMetersBetweenMapPoints(userPoint, projected);
+        if (dist < best.perpDistance) {
+            best.perpDistance = dist;
+            best.projectedPoint = projected;
+            best.segmentIndex = i;
+        }
+    }
+    return best;
+}
 
