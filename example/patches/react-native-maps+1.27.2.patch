+
+static inline void fromRawValue(const PropsParserContext& context, const RawValue &value, RNMapsNavigationCoordinateStruct &result) {
+  auto map = (std::unordered_map<std::string, RawValue>)value;
+
+  auto tmp_latitude = map.find("latitude");
+  if (tmp_latitude != map.end()) {
+    fromRawValue(context, tmp_latitude->second, result.latitude);
+  }
+  auto tmp_longitude = map.find("longitude");
+  if (tmp_longitude != map.end()) {
+    fromRawValue(context, tmp_longitude->second, result.longitude);
+  }
+}
+
+static inline std::string toString(const RNMapsNavigationCoordinateStruct &value) {
+  return "[Object RNMapsNavigationCoordinateStruct]";
+}
+
+#ifdef RN_SERIALIZABLE_STATE
